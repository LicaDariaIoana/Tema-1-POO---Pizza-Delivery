class info_pizza{
private:
    char nume[100], topinguri[100], blat[100], sos[100];
    static int nrPizza;

public:
// constructori deafault
info_pizza() {
    strcpy(nume, "");
    strcpy(topinguri, "");
    strcpy(blat, "");
    strcpy(sos, "");
}

// constructor cu parametri/ de initializare
info_pizza(const char* n, const char* t, const char* b, const char* s) {
    strcpy(nume, n);
    strcpy(topinguri, t);
    strcpy(blat, b);
    strcpy(sos, s);
    nrPizza++;
}

// constructor de copiere, pt inca o pizza
info_pizza(const info_pizza& inca_una){
	strcpy(nume, inca_una.nume);
	strcpy(topinguri, inca_una.topinguri);
	strcpy(blat, inca_una.blat);
	strcpy(sos,inca_una.sos);
}
// destructorul
~info_pizza(){}

//functie statica pt nr de pizze
static int getTotalPizze() { return nrPizza; }

//geteri:
inline const char* getNume() const{return nume;}
inline const char* getTopinguri() const{return topinguri;}
inline const char* getBlat() const{return blat;}
inline const char* getSos() const{return sos;}

//setarii:
void setNume(const char* n) {
    if (n != nullptr && strlen(n) < 100)
        strcpy(nume, n);}

void setTopinguri(const char* t) {
    if (t != nullptr && strlen(t) < 100)
        strcpy(topinguri, t);}

void setBlat(const char* b) {
    if (b != nullptr && strlen(b) < 100)
        strcpy(blat, b);}

void setSos(const char* s) {
    if (s != nullptr && strlen(s) < 100)
        strcpy(sos, s);}

//functie pt citire(>>) pentru info pizza, nu e necesar pt cod dar lam pastrat
friend std::istream& operator>>(std::istream& citire_pizza, info_pizza& p){
    citire_pizza>>p.nume>>p.topinguri>>p.blat>>p.sos;
    return citire_pizza;}

// functia pt afisare(<<) pentru info pizaa
friend std::ostream& operator<<(std::ostream& afisare_pizza, const info_pizza& p){
    afisare_pizza<< "Tipul de pizza: "<<p.nume<<", topinguri: "<<p.topinguri<<", blat: "<<p.blat<<", sos: "<<p.sos<<";"<<std::endl;
    return afisare_pizza;}

//functia pt =
info_pizza& operator=(const info_pizza& p) {
    if (this != &p) {
        strcpy(nume, p.nume);
        strcpy(topinguri, p.topinguri);
        strcpy(blat, p.blat);
        strcpy(sos, p.sos);
    }
    return *this;
}};
int info_pizza::nrPizza = 0;

